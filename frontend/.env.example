# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so real endpoints/secrets never get committed.
#
# The contact form posts to a form-backend-as-a-service (Formspree,
# Web3Forms, Netlify Forms, etc.) — no custom backend required.
# Leave this blank to keep the form in "phone/email fallback" mode.
#
# Vite only exposes variables prefixed with VITE_ to the frontend.
VITE_CONTACT_FORM_ENDPOINT=
