# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so environment-specific config never gets committed.
#
# The contact form submits via Formspree (form-backend-as-a-service) — no custom
# backend required. The form ID below is a PUBLIC identifier (it's visible in the
# page's network requests either way), not a secret.
#
# Vite only exposes variables prefixed with VITE_ to the frontend.
# Leave this unset to use the default form ID baked into the app.
VITE_FORMSPREE_FORM_ID=maqgkpdg
